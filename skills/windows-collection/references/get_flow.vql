SELECT
  session_id,
  state,
  total_collected_rows,
  artifacts_with_results,
  request.timeout AS RequestTimeoutSeconds,
  request.artifacts AS RequestedArtifacts,
  serialize(format='json', item=request.specs) AS RequestSpecsJson,
  timestamp(epoch=create_time) AS Created,
  timestamp(epoch=active_time) AS LastActive
FROM flows(client_id=client_id)
WHERE session_id = flow_id
